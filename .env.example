# Database connection string (from Supabase or other PostgreSQL provider)
DATABASE_URL=postgresql://user:password@host:port/database

# Secret key for JWT token signing. REQUIRED — the app refuses to start
# without one of at least 32 characters. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Set to "production" on deployed environments (marks the session cookie Secure)
ENVIRONMENT=development

# SameSite policy for the session cookie.
#   lax  (default) — use when the frontend and API share a domain
#                    (e.g. CloudFront routes /api/* to the backend).
#   none           — required if the frontend and API are on DIFFERENT domains;
#                    forces the Secure flag (HTTPS only).
COOKIE_SAMESITE=lax

# Session lifetime in minutes (the frontend refreshes active sessions)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Production frontend URL, added to CORS + CSRF allowed origins
FRONTEND_URL=

# Comma-separated emails of admins allowed to create/delete tenants and view
# users across all facilities. Admins not on this list manage only their own
# facility. Empty = tenant management only via backend scripts.
PLATFORM_ADMIN_EMAILS=

# Maximum upload size for validation files, in megabytes
MAX_UPLOAD_MB=25

# Email service configuration (optional; if unset, temp passwords are shown
# once to the creating admin instead of emailed)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
